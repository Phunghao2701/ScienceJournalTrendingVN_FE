{
  "version": 2,
  "scope": "repo",
  "repo": "E:/Science_Journal_Trending_VN/ScienceJournalTrendingVN_FE",
  "server": {
    "host": "127.0.0.1",
    "port": 8765,
    "transport": "http"
  },
  "auth": {
    "mode": "oauth",
    "oauthFile": ".repo-harness/mcp.oauth.json",
    "tokenFile": ".repo-harness/mcp.tokens.json"
  },
  "chatgpt": {
    "serverName": "repo-harness",
    "endpoint": "https://assets-weighted-ringtone-arg.trycloudflare.com/mcp"
  },
  "capabilities": {
    "workspaceReader": true,
    "workflowPlanner": true,
    "workflowExecutor": false,
    "agentRunner": false
  },
  "permissions": {
    "allowedRoots": [],
    "discoveryRoots": [],
    "fullDiskRead": false
  },
  "rollout": {
    "generalRepo": {
      "general_repo_read": false,
      "repo_write": false,
      "fs_fallback": false,
      "shadow_compare": false,
      "canary_repos": [],
      "rollback_to_legacy_tools": false
    }
  },
  "profile": "planner",
  "devMode": {
    "agentRunner": false,
    "allowedAgents": [
      "codex"
    ],
    "timeoutMs": 120000
  }
}
